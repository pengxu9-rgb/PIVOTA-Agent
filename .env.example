# Example environment for local development.
# Never commit real keys/passwords to the repo.

PORT=3000

# Pivota upstream API (required for /agent/* proxy routes)
PIVOTA_API_BASE=https://api.example.com
PIVOTA_API_KEY=REPLACE_ME

# External invoke auth (single key for both shop + creator invoke routes)
AGENT_AUTH_INTROSPECT_URL=https://api.example.com/agent/internal/auth/introspect
AGENT_AUTH_INTROSPECT_INTERNAL_KEY=REPLACE_ME
AGENT_AUTH_INTROSPECT_TIMEOUT_MS=2500
AGENT_AUTH_CACHE_POSITIVE_TTL_MS=60000
AGENT_AUTH_CACHE_NEGATIVE_TTL_MS=15000
AGENT_AUTH_CACHE_MAX_ENTRIES=20000

# Local mock Pivota (optional)
MOCK_PIVOTA_PORT=3999

# LLM providers (optional)
OPENAI_API_KEY=REPLACE_ME

# Public gateway url (optional; used for callback/links in some flows)
PIVOTA_GATEWAY_URL=http://localhost:3000

# Look Replicator API auth (required for /api/look-replicate/* routes)
LOOK_REPLICATOR_API_KEY=REPLACE_ME

# Upload limits (optional)
LOOK_REPLICATOR_MAX_UPLOAD_BYTES=10485760
LOOK_REPLICATOR_SIGNED_URL_TTL_SECONDS=900

# Aurora Beauty aggressive internal rollout defaults (100% internal traffic)
AURORA_RULE_RELAX_MODE=aggressive
AURORA_KB_WRITE_POLICY=allow_all
AURORA_KB_SERVE_POLICY=serve_with_labels
AURORA_PRODUCT_GUARDRAIL_MODE=telemetry_only
AURORA_PRODUCT_STRICT_SKINCARE_FILTER=false

# Asset storage (optional)
LOOK_REPLICATOR_S3_ENDPOINT=https://s3.example.com
LOOK_REPLICATOR_S3_REGION=auto
LOOK_REPLICATOR_S3_BUCKET=look-replicator
LOOK_REPLICATOR_S3_ACCESS_KEY_ID=REPLACE_ME
LOOK_REPLICATOR_S3_SECRET_ACCESS_KEY=REPLACE_ME

# Public base URL for assets (optional)
LOOK_REPLICATOR_PUBLIC_ASSET_BASE_URL=https://assets.example.com/look-replicator

# Aurora BFF Auth (required for /v1/auth/* sign-in flow)
AURORA_BFF_AUTH_ENABLED=true
AURORA_BFF_AUTH_PEPPER=REPLACE_ME

# Email provider: sendgrid | resend | ses (auto-detected from API key if omitted)
AURORA_BFF_AUTH_EMAIL_PROVIDER=sendgrid
AURORA_BFF_AUTH_EMAIL_FROM=Aurora <noreply@pivota.ai>

# SendGrid (if EMAIL_PROVIDER=sendgrid or auto-detected)
SENDGRID_API_KEY=REPLACE_ME

# Resend (if EMAIL_PROVIDER=resend or auto-detected)
# RESEND_API_KEY=REPLACE_ME

# AWS SES (if EMAIL_PROVIDER=ses; uses standard AWS credentials)
# AURORA_BFF_AUTH_SES_REGION=us-east-1
