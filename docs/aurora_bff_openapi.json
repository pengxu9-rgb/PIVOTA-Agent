{
  "openapi": "3.1.0",
  "info": {
    "title": "Pivota Agent Aurora BFF",
    "version": "0.1.0",
    "description": "BFF/Orchestrator for aurora.pivota.cc chat. `POST /v1/chat` returns ChatCards Response Schema v1. Other /v1 endpoints in this document still return the legacy envelope."
  },
  "servers": [
    {
      "url": "https://pivota-agent-production.up.railway.app"
    }
  ],
  "components": {
    "schemas": {
      "AssistantMessage": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "content"],
        "properties": {
          "role": { "const": "assistant" },
          "content": { "type": "string" },
          "format": { "type": "string", "enum": ["text", "markdown"] }
        }
      },
      "SuggestedChip": {
        "type": "object",
        "additionalProperties": false,
        "required": ["chip_id", "label"],
        "properties": {
          "chip_id": { "type": "string" },
          "label": { "type": "string" },
          "kind": { "type": "string", "enum": ["quick_reply", "action"] },
          "data": { "type": "object", "additionalProperties": true }
        }
      },
      "FieldMissing": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "reason"],
        "properties": {
          "field": { "type": "string" },
          "reason": { "type": "string" }
        }
      },
      "Card": {
        "type": "object",
        "additionalProperties": false,
        "required": ["card_id", "type", "payload"],
        "properties": {
          "card_id": { "type": "string" },
          "type": { "type": "string" },
          "title": { "type": "string" },
          "payload": { "type": "object", "additionalProperties": true },
          "field_missing": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/FieldMissing" }
          }
        }
      },
      "SessionPatch": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "next_state": { "type": "string" }
        }
      },
      "V1ResponseEnvelope": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "request_id",
          "trace_id",
          "assistant_message",
          "suggested_chips",
          "cards",
          "session_patch",
          "events"
        ],
        "properties": {
          "request_id": { "type": "string" },
          "trace_id": { "type": "string" },
          "assistant_message": { "anyOf": [{ "$ref": "#/components/schemas/AssistantMessage" }, { "type": "null" }] },
          "suggested_chips": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/SuggestedChip" }
          },
          "cards": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Card" }
          },
          "session_patch": { "$ref": "#/components/schemas/SessionPatch" },
          "events": {
            "type": "array",
            "items": { "type": "object", "additionalProperties": true }
          }
        }
      },
      "ChatCardV1": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "priority", "title", "tags", "sections", "actions"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["product_verdict", "compatibility", "routine", "triage", "skin_status", "effect_review", "travel", "nudge"]
          },
          "priority": { "type": "integer", "minimum": 1, "maximum": 3 },
          "title": { "type": "string" },
          "subtitle": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "sections": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "actions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "label"],
              "properties": {
                "type": { "type": "string" },
                "label": { "type": "string" },
                "payload": { "type": "object", "additionalProperties": true }
              }
            }
          }
        }
      },
      "QuickReplyV1": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "value": { "type": "string" },
          "metadata": { "type": "object", "additionalProperties": true }
        }
      },
      "FollowUpQuestionV1": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "question", "options", "required"],
        "properties": {
          "id": { "type": "string" },
          "question": { "type": "string" },
          "options": { "type": "array", "items": { "$ref": "#/components/schemas/QuickReplyV1" } },
          "required": { "type": "boolean" }
        }
      },
      "ThreadOpV1": {
        "type": "object",
        "additionalProperties": false,
        "required": ["op", "topic_id"],
        "properties": {
          "op": { "type": "string", "enum": ["thread_push", "thread_pop", "thread_update"] },
          "topic_id": { "type": "string" },
          "summary": { "type": "string" },
          "timestamp_ms": { "type": "integer", "minimum": 0 }
        }
      },
      "ChatCardsOpsV1": {
        "type": "object",
        "additionalProperties": false,
        "required": ["thread_ops", "profile_patch", "routine_patch", "experiment_events"],
        "properties": {
          "thread_ops": { "type": "array", "items": { "$ref": "#/components/schemas/ThreadOpV1" } },
          "profile_patch": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "routine_patch": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "experiment_events": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
        }
      },
      "ChatCardsSafetyV1": {
        "type": "object",
        "additionalProperties": false,
        "required": ["risk_level", "red_flags", "disclaimer"],
        "properties": {
          "risk_level": { "type": "string", "enum": ["none", "low", "medium", "high"] },
          "red_flags": { "type": "array", "items": { "type": "string" } },
          "disclaimer": { "type": "string" }
        }
      },
      "ChatCardsTelemetryV1": {
        "type": "object",
        "additionalProperties": false,
        "required": ["intent", "intent_confidence", "entities"],
        "properties": {
          "intent": { "type": "string" },
          "intent_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "entities": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
        }
      },
      "ChatCardsResponseV1": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "version",
          "request_id",
          "trace_id",
          "assistant_text",
          "cards",
          "follow_up_questions",
          "suggested_quick_replies",
          "ops",
          "safety",
          "telemetry"
        ],
        "properties": {
          "version": { "const": "1.0" },
          "request_id": { "type": "string" },
          "trace_id": { "type": "string" },
          "assistant_text": { "type": "string" },
          "cards": { "type": "array", "maxItems": 3, "items": { "$ref": "#/components/schemas/ChatCardV1" } },
          "follow_up_questions": { "type": "array", "maxItems": 3, "items": { "$ref": "#/components/schemas/FollowUpQuestionV1" } },
          "suggested_quick_replies": { "type": "array", "maxItems": 8, "items": { "$ref": "#/components/schemas/QuickReplyV1" } },
          "ops": { "$ref": "#/components/schemas/ChatCardsOpsV1" },
          "safety": { "$ref": "#/components/schemas/ChatCardsSafetyV1" },
          "telemetry": { "$ref": "#/components/schemas/ChatCardsTelemetryV1" }
        }
      },
      "UiEventV0": {
        "type": "object",
        "additionalProperties": false,
        "required": ["event_name", "brief_id", "trace_id", "timestamp"],
        "properties": {
          "event_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "description": "UI event name. Common names: intent_detected, card_impression, card_action_click, triage_stage_shown, triage_action_tap, nudge_action_tap.",
            "examples": ["card_impression", "triage_stage_shown", "nudge_action_tap"]
          },
          "brief_id": { "type": "string", "minLength": 1, "maxLength": 120 },
          "trace_id": { "type": "string", "minLength": 1, "maxLength": 120 },
          "timestamp": { "type": "number", "minimum": 0 },
          "data": { "type": "object", "additionalProperties": true }
        }
      },
      "UiEventIngestV0": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "events"],
        "properties": {
          "source": { "type": "string", "minLength": 1, "maxLength": 120 },
          "events": {
            "type": "array",
            "minItems": 1,
            "maxItems": 50,
            "items": { "$ref": "#/components/schemas/UiEventV0" }
          }
        }
      }
    },
    "parameters": {
      "X-Aurora-UID": {
        "name": "X-Aurora-UID",
        "in": "header",
        "required": true,
        "schema": { "type": "string" }
      },
      "X-Brief-ID": {
        "name": "X-Brief-ID",
        "in": "header",
        "required": false,
        "schema": { "type": "string" }
      },
      "X-Trace-ID": {
        "name": "X-Trace-ID",
        "in": "header",
        "required": false,
        "schema": { "type": "string" }
      },
      "X-Lang": {
        "name": "X-Lang",
        "in": "header",
        "required": false,
        "schema": { "type": "string", "enum": ["EN", "CN"] }
      }
    }
  },
  "paths": {
    "/v1/chat": {
      "post": {
        "summary": "Chat (main entry)",
        "parameters": [
          { "$ref": "#/components/parameters/X-Aurora-UID" },
          { "$ref": "#/components/parameters/X-Brief-ID" },
          { "$ref": "#/components/parameters/X-Trace-ID" },
          { "$ref": "#/components/parameters/X-Lang" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "message": { "type": "string" },
                  "action": {
                    "anyOf": [
                      { "type": "string" },
                      {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["action_id"],
                        "properties": {
                          "action_id": { "type": "string" },
                          "kind": { "type": "string", "enum": ["chip", "action"] },
                          "data": { "type": "object", "additionalProperties": true }
                        }
                      }
                    ]
                  },
                  "session": { "type": "object", "additionalProperties": true },
                  "language": { "type": "string", "enum": ["EN", "CN"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ChatCardsResponseV1" }
              }
            }
          }
        }
      }
    },
    "/v1/product/parse": {
      "post": {
        "summary": "Parse product input (name/link → product entity)",
        "parameters": [
          { "$ref": "#/components/parameters/X-Aurora-UID" },
          { "$ref": "#/components/parameters/X-Brief-ID" },
          { "$ref": "#/components/parameters/X-Trace-ID" },
          { "$ref": "#/components/parameters/X-Lang" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/V1ResponseEnvelope" }
              }
            }
          }
        }
      }
    },
    "/v1/product/analyze": {
      "post": {
        "summary": "Product deep scan (evidence chain required)",
        "parameters": [
          { "$ref": "#/components/parameters/X-Aurora-UID" },
          { "$ref": "#/components/parameters/X-Brief-ID" },
          { "$ref": "#/components/parameters/X-Trace-ID" },
          { "$ref": "#/components/parameters/X-Lang" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/V1ResponseEnvelope" }
              }
            }
          }
        }
      }
    },
    "/v1/dupe/compare": {
      "post": {
        "summary": "Dupe/competitor compare (tradeoffs + evidence)",
        "parameters": [
          { "$ref": "#/components/parameters/X-Aurora-UID" },
          { "$ref": "#/components/parameters/X-Brief-ID" },
          { "$ref": "#/components/parameters/X-Trace-ID" },
          { "$ref": "#/components/parameters/X-Lang" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/V1ResponseEnvelope" }
              }
            }
          }
        }
      }
    },
    "/v1/reco/generate": {
      "post": {
        "summary": "Generate recommendations (explicit trigger only; default affiliate outbound)",
        "parameters": [
          { "$ref": "#/components/parameters/X-Aurora-UID" },
          { "$ref": "#/components/parameters/X-Brief-ID" },
          { "$ref": "#/components/parameters/X-Trace-ID" },
          { "$ref": "#/components/parameters/X-Lang" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/V1ResponseEnvelope" }
              }
            }
          }
        }
      }
    },
    "/v1/photos/presign": {
      "post": {
        "summary": "Presign photo upload (can be stubbed)",
        "parameters": [
          { "$ref": "#/components/parameters/X-Aurora-UID" },
          { "$ref": "#/components/parameters/X-Brief-ID" },
          { "$ref": "#/components/parameters/X-Trace-ID" },
          { "$ref": "#/components/parameters/X-Lang" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/V1ResponseEnvelope" }
              }
            }
          }
        }
      }
    },
    "/v1/photos/confirm": {
      "post": {
        "summary": "Confirm photo upload + QC status (passed/too_dark/has_filter/blurry)",
        "parameters": [
          { "$ref": "#/components/parameters/X-Aurora-UID" },
          { "$ref": "#/components/parameters/X-Brief-ID" },
          { "$ref": "#/components/parameters/X-Trace-ID" },
          { "$ref": "#/components/parameters/X-Lang" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/V1ResponseEnvelope" }
              }
            }
          }
        }
      }
    },
    "/v1/events": {
      "post": {
        "summary": "Ingest Aurora chatbox UI analytics events",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UiEventIngestV0" },
              "examples": {
                "triageStageShown": {
                  "summary": "Triage stage impression",
                  "value": {
                    "source": "pivota-aurora-chatbox",
                    "events": [
                      {
                        "event_name": "triage_stage_shown",
                        "brief_id": "b",
                        "trace_id": "t",
                        "timestamp": 1700000000000,
                        "data": {
                          "aurora_uid": "uid_test",
                          "lang": "EN",
                          "state": "IDLE_CHAT",
                          "card_id": "triage_1",
                          "card_position": 0,
                          "risk_level": "high",
                          "recovery_window_hours": 48,
                          "red_flag_count": 2,
                          "action_point_count": 3
                        }
                      }
                    ]
                  }
                },
                "nudgeActionTap": {
                  "summary": "Nudge action click",
                  "value": {
                    "source": "pivota-aurora-chatbox",
                    "events": [
                      {
                        "event_name": "nudge_action_tap",
                        "brief_id": "b",
                        "trace_id": "t",
                        "timestamp": 1700000000001,
                        "data": {
                          "aurora_uid": "uid_test",
                          "lang": "EN",
                          "state": "IDLE_CHAT",
                          "card_id": "nudge_1",
                          "action_type": "save_tip",
                          "action_label": "Save tip",
                          "cadence_days": 7,
                          "hint_count": 1
                        }
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "No Content" },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": { "type": "object", "additionalProperties": true }
              }
            }
          }
        }
      }
    },
    "/v1/session/bootstrap": {
      "get": {
        "summary": "Bootstrap session context (profile + recent logs)",
        "parameters": [
          { "$ref": "#/components/parameters/X-Aurora-UID" },
          { "$ref": "#/components/parameters/X-Brief-ID" },
          { "$ref": "#/components/parameters/X-Trace-ID" },
          { "$ref": "#/components/parameters/X-Lang" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/V1ResponseEnvelope" }
              }
            }
          }
        }
      }
    },
    "/v1/profile/update": {
      "post": {
        "summary": "Update user profile (partial)",
        "parameters": [
          { "$ref": "#/components/parameters/X-Aurora-UID" },
          { "$ref": "#/components/parameters/X-Brief-ID" },
          { "$ref": "#/components/parameters/X-Trace-ID" },
          { "$ref": "#/components/parameters/X-Lang" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/V1ResponseEnvelope" }
              }
            }
          }
        }
      }
    },
    "/v1/tracker/log": {
      "post": {
        "summary": "Create/update a daily SkinLog entry",
        "parameters": [
          { "$ref": "#/components/parameters/X-Aurora-UID" },
          { "$ref": "#/components/parameters/X-Brief-ID" },
          { "$ref": "#/components/parameters/X-Trace-ID" },
          { "$ref": "#/components/parameters/X-Lang" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/V1ResponseEnvelope" }
              }
            }
          }
        }
      }
    },
    "/v1/tracker/recent": {
      "get": {
        "summary": "Get recent SkinLog entries",
        "parameters": [
          { "$ref": "#/components/parameters/X-Aurora-UID" },
          { "$ref": "#/components/parameters/X-Brief-ID" },
          { "$ref": "#/components/parameters/X-Trace-ID" },
          { "$ref": "#/components/parameters/X-Lang" },
          {
            "name": "days",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "maximum": 30, "default": 7 }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/V1ResponseEnvelope" }
              }
            }
          }
        }
      }
    },
    "/v1/routine/simulate": {
      "post": {
        "summary": "Simulate routine compatibility/conflicts (rule-based fallback)",
        "parameters": [
          { "$ref": "#/components/parameters/X-Aurora-UID" },
          { "$ref": "#/components/parameters/X-Brief-ID" },
          { "$ref": "#/components/parameters/X-Trace-ID" },
          { "$ref": "#/components/parameters/X-Lang" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/V1ResponseEnvelope" }
              }
            }
          }
        }
      }
    },
    "/v1/offers/resolve": {
      "post": {
        "summary": "Resolve offers (affiliate outbound first)",
        "parameters": [
          { "$ref": "#/components/parameters/X-Aurora-UID" },
          { "$ref": "#/components/parameters/X-Brief-ID" },
          { "$ref": "#/components/parameters/X-Trace-ID" },
          { "$ref": "#/components/parameters/X-Lang" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/V1ResponseEnvelope" }
              }
            }
          }
        }
      }
    },
    "/v1/affiliate/outcome": {
      "post": {
        "summary": "Report affiliate/outbound outcome (success/failed/save)",
        "parameters": [
          { "$ref": "#/components/parameters/X-Aurora-UID" },
          { "$ref": "#/components/parameters/X-Brief-ID" },
          { "$ref": "#/components/parameters/X-Trace-ID" },
          { "$ref": "#/components/parameters/X-Lang" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "required": ["outcome"],
                "properties": {
                  "outcome": { "type": "string", "enum": ["success", "failed", "save"] },
                  "url": { "type": "string" },
                  "offer_id": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
