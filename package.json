    "benchmark:routine:multiturn:run": "node scripts/run_routine_multiturn_seed_cases.cjs --dataset datasets/routine_expert_multiturn_seed.json",
    "benchmark:routine:multiturn:export": "node scripts/export_routine_multiturn_scoring_packets.cjs --dataset datasets/routine_expert_multiturn_seed.json",
    "benchmark:routine:eval": "node scripts/eval_routine_expert_benchmark.cjs",
    "benchmark:routine:multiturn:eval": "node scripts/eval_routine_expert_benchmark.cjs --dataset datasets/routine_expert_multiturn_seed.json --aurora reports/routine-expert-multiturn/aurora_scores.json --gemini reports/routine-expert-multiturn/gemini_scores.json",
    "gate:routine-expert:benchmark": "bash scripts/gate_routine_expert_benchmark.sh",
    "eval:aurora:nightly-full": "node scripts/aurora_chat_v2_nightly_full_eval.js",
