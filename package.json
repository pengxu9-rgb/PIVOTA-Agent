    "audit:aurora:prompt-specs": "node scripts/export_aurora_prompt_spec_matrix.cjs",
    "test:aurora:skills": "node tests/skills/test_skill_contract.js",
    "test:aurora:skills:live": "AURORA_SKILL_CONTRACT_LIVE=1 node tests/skills/test_skill_contract.js",
    "test:aurora:routes:v2": "node --test tests/aurora_chat_v2_routes.node.test.cjs",
    "gate:aurora:travel20": "node scripts/aurora_travel_gate.js",
    "gate:aurora:safety20": "node scripts/aurora_travel_gate.js --cases tests/golden/aurora_safety_20.jsonl --report-prefix aurora_safety_gate",
    "gate:aurora:anchor20": "node scripts/aurora_travel_gate.js --cases tests/golden/aurora_anchor_eval_20.jsonl --report-prefix aurora_anchor_eval_gate",
    "benchmark:travel:efgh:staging": "node scripts/aurora_travel_gate.js --mode staging-live --cases tests/golden/aurora_travel_efgh_4.jsonl --expected-count 4 --report-prefix aurora_travel_efgh_gate",
    "benchmark:travel:efgh:prod": "node scripts/aurora_travel_gate.js --mode staging-live --base https://pivota-agent-production.up.railway.app --cases tests/golden/aurora_travel_efgh_4.jsonl --expected-count 4 --report-prefix aurora_travel_efgh_gate",
    "benchmark:travel:multiturn:run": "node scripts/run_travel_multiturn_seed_cases.cjs",
    "benchmark:travel:multiturn:export": "node scripts/export_travel_multiturn_scoring_packets.cjs",
    "benchmark:travel:multiturn:eval": "node scripts/eval_travel_expert_benchmark.cjs",
    "gate:aurora:pr-lite": "AURORA_CHAT_RESPONSE_FORMAT=legacy node scripts/aurora_chat_v2_pr_lite_gate.js",
    "benchmark:routine:dataset": "node scripts/build_routine_expert_benchmark_120.cjs",
    "benchmark:routine:init-templates": "node scripts/init_routine_expert_score_templates.cjs",
