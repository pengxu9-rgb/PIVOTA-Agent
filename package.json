    "diag:gold:sample": "node scripts/sample_gold_label_tasks.js",
    "diag:gold:import": "node scripts/import_gold_labels.js",
    "diag:gold:seed-pack": "node scripts/gold_seed_pack.mjs",
    "diag:gold:import:v2": "node scripts/gold_label_import.mjs",
    "diag:gold:eval": "node scripts/eval_gold.mjs",
    "diag:calibrator:train": "node scripts/train_calibrator.js",
    "smoke:lookreplicate:activity": "node scripts/smoke-lookreplicate-activity-slot.js",
    "probe:frontend:winona-ipsa": "node scripts/run_frontend_live_regression_winona_ipsa.js",
    "probe:frontend:winona-ipsa:fixed": "WARMUP_ROUNDS=1 FORMAL_ROUNDS=100 node scripts/run_frontend_live_regression_winona_ipsa.js",
    "probe:search:stability": "node scripts/search_stability_matrix.js",
    "obs:snapshot:export": "node scripts/export_observability_snapshot.js",
    "probe:route:prod": "node scripts/probe_prod_route_chain.js",
    "probe:aurora:rollout": "node scripts/aurora_rollout_probe.js",
    "probe:aurora:reco:prod-manual": "node scripts/aurora_reco_prod_manual_suite.cjs",
    "probe:aurora:reco:prompt-extract": "node scripts/aurora_reco_prompt_extract.cjs",
    "probe:aurora:reco:baseline-snapshot": "node scripts/aurora_reco_baseline_snapshot.cjs",
    "verify:aurora:contracts": "node scripts/verify_aurora_contracts_sync.cjs",
