    "test:node:legacy-contract": "npm run test:preflight && AURORA_BFF_USE_MOCK=true AURORA_CHAT_RESPONSE_FORMAT=legacy node --test tests/aurora_bff_legacy_contract.node.test.cjs",
    "test:jest": "npm run test:preflight && AURORA_BFF_PDP_HOTSET_PREWARM_ENABLED=false node scripts/jest_sharded_run.cjs",
    "test:file": "bash scripts/test_file.sh",
    "eval:layer1:us": "node src/eval/layer1/us/runEval.js",
    "eval:layer2_3:us": "node src/eval/layer2_3/us/runEval.js",
    "contract:export": "node scripts/export-contracts-us.js && node scripts/export-contracts-jp.js",
    "contract:export:l2l3": "node scripts/export-contracts-us.js --l2l3 && node scripts/export-contracts-jp.js --l2l3",
    "contract:test": "npm run test:preflight && node ./node_modules/.bin/jest --watchman=false --runInBand tests/layer1/contracts_us.test.js tests/layer2_3/contracts_us.test.js tests/layer2_3/contracts_jp.test.js tests/layer1/contracts_manifest_us.test.js tests/layer2_3/contracts_manifest_jp.test.js",
    "test:aurora-bff:unit": "npm run test:node",
    "test:aurora-bff:product-intel:stable": "npm run test:preflight && AURORA_BFF_USE_MOCK=true AURORA_CHAT_RESPONSE_FORMAT=legacy node ./node_modules/.bin/jest --watchman=false --runInBand --forceExit --roots tests --runTestsByPath tests/aurora_bff_product_intel.test.js tests/aurora_bff_product_intel_public_payload.test.js",
    "test:replay-quality": "node scripts/replay_quality.js --quiet",
    "ci:layer1": "npm run test && npm run contract:test && npm run eval:layer1:us",
    "demo:openai": "node scripts/demo-openai-pivota.mjs",
    "lint:kb:us": "node scripts/lint-technique-kb-us.js",
    "lint:kb:jp": "node scripts/lint-technique-kb-jp.js",
    "lint:kb:trigger-producibility:us": "node scripts/lint-kb-trigger-producibility.js --market US",
    "lint:kb:trigger-producibility:jp": "node scripts/lint-kb-trigger-producibility.js --market JP",
    "lint:kb:role-hints:us": "node scripts/lint-kb-role-hints.js --market US",
    "lint:kb:role-hints:jp": "node scripts/lint-kb-role-hints.js --market JP",
    "kb:import:csv": "node scripts/kb-import-csv.js",
    "kb:check:mapping": "node scripts/kb-check-mapping.js",
    "kb:analyze": "node src/kb/runAnalyzeKBHealth.js",
    "kb:analyze:us": "node src/kb/runAnalyzeKBHealth.js --market=US",
    "kb:analyze:jp": "node src/kb/runAnalyzeKBHealth.js --market=JP",
    "kb:replay": "node src/kb/runReplayKB.js",
    "kb:starter:generate": "node scripts/generate-starter-kb.js",
    "kb:propose:us": "node src/kb/us/proposeNewTechniqueCards.js",
    "handbook:generate": "node scripts/generate-content-handbook.js",
    "external:build-pool": "node scripts/build-external-links-pool.js",
    "external:lint": "node scripts/lint-external-offers-pool.js",
    "external:report": "node scripts/report-external-links-pool.js",
    "external:report:us": "node scripts/report-external-links-pool.js --market US",
    "external:report:jp": "node scripts/report-external-links-pool.js --market JP",
    "internal:build-pins": "node scripts/build-internal-pins.js",
    "internal:lint": "node scripts/lint-internal-pins.js",
    "internal:report": "node scripts/report-internal-pins.js",
    "internal:report:us": "node scripts/report-internal-pins.js --market US",
    "internal:report:jp": "node scripts/report-internal-pins.js --market JP",
    "verify:premerge": "node scripts/verify-pr-file-boundary.js && node scripts/verify-premerge-layer2-slots.js && node scripts/verify-bilingual-resolution.js && node scripts/verify-jp-placeholder-noncrash.js && node scripts/verify-selection-stability.js",
    "mock:pivota": "node scripts/mock-pivota-api.js",
    "demo:status": "node scripts/demo-openai-status.mjs",
    "embeddings:backfill": "node scripts/backfill-products-cache-embeddings.js",
    "external-seeds:backfill:catalog": "node scripts/backfill-external-product-seeds-catalog.js",
    "external-seeds:audit:content": "node scripts/audit-external-product-seeds-content.js",
    "external-seeds:correct": "node scripts/correct-external-product-seeds.js",
    "external-seeds:export:harvester": "node scripts/export-external-seeds-harvester-candidates.js",
    "ingredient-harvester:batch": "node scripts/ingredient-harvester-batch.js",
    "ingredient:ingest": "node scripts/ingest_ingredient_sources.js",
    "ingredient:ingest:dry": "node scripts/ingest_ingredient_sources.js --dry-run --fail-on-audit",
    "ingredient:audit": "node scripts/ingest_ingredient_sources.js --audit-only --fail-on-audit",
    "photo:llm-review:batch": "node scripts/batch_photo_llm_review_pack.mjs",
    "photo:llm-review:baseline": "node scripts/build_product_intel_fallback_baseline.mjs",
    "deploy:verify:production": "bash scripts/verify_deployed_commit_matches.sh"
