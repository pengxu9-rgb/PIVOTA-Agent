{
  "name": "pivota-agent-gateway",
  "version": "0.1.0",
  "description": "Thin gateway for Pivota Shopping Agent: routes /agent/shop/v1/invoke to internal Pivota API operations.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:mock": "USE_MOCK=true node src/server.js",
    "dev": "node src/server.js",
    "dev:mock": "USE_MOCK=true node src/server.js",
    "smoke:layer2": "node scripts/smoke-layer2.js",
    "smoke:travel-plans:runtime": "bash scripts/smoke_travel_plans_runtime.sh",
    "probe:travel-plans:synthetic": "bash scripts/travel_plans_synthetic_probe.sh",
    "rollback:webhook": "bash scripts/trigger_rollback_webhook.sh",
    "diag:calibration:train": "node scripts/train_diag_calibration.js",
    "diag:calibration:eval": "node scripts/eval_calibration.js",
    "diag:boxqc:llm:poc": "node scripts/llm_module_box_qc_poc.mjs",
    "diag:boxqc:llm:ab": "node scripts/llm_module_box_qc_ab_label.mjs",
    "diag:boxqc:llm:render": "node scripts/llm_module_box_qc_render_overlays.mjs",
