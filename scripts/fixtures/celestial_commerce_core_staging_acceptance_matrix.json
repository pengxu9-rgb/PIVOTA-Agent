  "governance_cases": [
    {
      "id": "public_direct_api_aurora_observed_block",
      "title": "public direct_api caller still observes orchestration denial in shadow mode",
      "family": "governance_orchestration_denied",
      "blocking": true,
      "endpoint": "/agent/shop/v1/invoke",
      "requires_auth": true,
      "auth_profile": "public",
      "headers": {
        "X-Pivota-Invocation-Surface": "direct_api"
      },
      "request": {
        "operation": "find_products_multi",
        "payload": {
          "search": {
            "query": "repair serum",
            "limit": 5,
            "in_stock_only": true
          }
        },
        "metadata": {
          "source": "aurora-bff"
        }
      },
      "correctness": {
        "mode": "auto",
        "expect_http_status": 200
      },
      "ownership": {
        "must_equal_headers": {
          "x-gateway-governance-observed-action": "block"
        },
        "must_have_reason_codes": [
          "layer_not_allowed"
        ]
      },
      "observability": {
        "must_equal_headers": {
          "x-gateway-governance-mode": "shadow",
          "x-gateway-governance-would-enforce": "true",
          "x-gateway-invocation-surface": "direct_api"
        },
        "must_have_paths": [
          "metadata.gateway_governance.mode",
          "metadata.gateway_governance.query_governance.reason_codes.0",
          "metadata.gateway_invocation.surface"
        ],
        "must_equal_paths": {
          "metadata.gateway_governance.mode": "shadow",
          "metadata.gateway_invocation.surface": "direct_api"
        }
      }
    },
