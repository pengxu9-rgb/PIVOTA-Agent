{
  "semantic_cases": [
    {
      "id": "staging_invoke_auth_smoke",
      "title": "staging invoke auth smoke",
      "family": "strict_consistency",
      "rail_mode": "authoritative_commerce",
      "require_primary_path": true,
      "allow_strict_empty": false,
      "allowed_query_sources": [
        "cache_multi_intent"
      ],
      "must_not_match_fallback_sources": [
        "agent_products_error_fallback",
        "agent_products_resolver_fallback",
        "agent_products_resolver_ref_fallback"
      ],
      "endpoint": "/agent/shop/v1/invoke",
      "requires_auth": true,
      "auth_profile": "default",
      "request": {
        "operation": "find_products_multi",
        "payload": {
          "search": {
            "query": "niacinamide serum",
            "limit": 5,
            "in_stock_only": true
          }
        },
        "metadata": {
          "source": "shopping_agent"
        }
      },
      "correctness": {
        "mode": "auto",
        "expect_http_status": 200,
        "allow_zero_results": false,
        "must_have_paths": [
          "metadata.contract_bridge.resolved_contract",
          "metadata.strict_constraint_query",
          "metadata.strict_constraint_reason",
          "metadata.matched_ingredient_ids.0"
        ],
        "must_equal_paths": {
          "metadata.contract_bridge.resolved_contract": "shop_invoke_strict",
          "metadata.strict_constraint_query": true,
          "metadata.strict_constraint_reason": "ingredient"
        }
      },
      "ownership": {
        "must_equal_paths": {
          "metadata.contract_bridge.resolved_contract": "shop_invoke_strict",
          "metadata.strict_constraint_query": true,
          "metadata.strict_constraint_reason": "ingredient"
        }
      },
      "observability": {
        "must_have_paths": [
          "metadata.service_version.commit",
          "metadata.search_trace.final_decision"
        ]
      }
    }
  ],
  "governance_cases": []
}
