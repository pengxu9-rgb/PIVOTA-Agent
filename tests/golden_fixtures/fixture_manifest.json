{
  "manifest_version": "1.0.0",
  "description": "Golden fixture test scenarios for Aurora skill regression testing. Each fixture defines a SkillRequest input and expected assertions on the SkillResponse.",
  "fixtures": [
    {
      "fixture_id": "gf_diagnosis_start_basic",
      "scenario": "New user starts diagnosis with no profile",
      "skill_id": "diagnosis_v2.start",
      "request": {
        "skill_id": "diagnosis_v2.start",
        "skill_version": "1.0.0",
        "intent": "skin_diagnosis",
        "params": {},
        "context": {
          "profile": {},
          "recent_logs": [],
          "travel_plan": null,
          "current_routine": null,
          "inventory": [],
          "locale": "zh-CN",
          "safety_flags": []
        },
        "thread_state": {}
      },
      "assertions": {
        "cards_min_count": 1,
        "cards_must_include_types": ["diagnosis_gate"],
        "next_actions_min_count": 1,
        "quality_ok": true,
        "must_not_contain_visual_analysis": true
      }
    },
    {
      "fixture_id": "gf_diagnosis_answer_no_photo",
      "scenario": "User answered diagnosis questions, no photo uploaded",
      "skill_id": "diagnosis_v2.answer",
      "request": {
        "skill_id": "diagnosis_v2.answer",
        "skill_version": "1.0.0",
        "intent": "skin_diagnosis",
        "params": {},
        "context": {
          "profile": { "has_photo": false, "skin_type": "combination" },
          "recent_logs": [],
          "travel_plan": null,
          "current_routine": null,
          "inventory": [],
          "locale": "en",
          "safety_flags": []
        },
        "thread_state": {
          "diagnosis_goals": ["acne", "hydration"]
        }
      },
      "assertions": {
        "cards_must_include_types": ["skin_status"],
        "next_actions_min_count": 2,
        "quality_ok": true,
        "must_not_contain_visual_analysis": true,
        "ops_profile_patch_must_include": ["skin_type", "primary_concerns"]
      }
    },
    {
      "fixture_id": "gf_routine_pregnancy_safety",
      "scenario": "Pregnant user generates routine: retinoids must be blocked",
      "skill_id": "routine.apply_blueprint",
      "request": {
        "skill_id": "routine.apply_blueprint",
        "skill_version": "1.0.0",
        "params": {},
        "context": {
          "profile": {
            "skin_type": "normal",
            "primary_concerns": ["anti_aging"],
            "has_photo": false
          },
          "recent_logs": [],
          "travel_plan": null,
          "current_routine": null,
          "inventory": [],
          "locale": "zh-CN",
          "safety_flags": ["PREG_RETINOID_BLOCK", "PREG_HIGH_STRENGTH_AHA_WARN"]
        },
        "thread_state": {
          "blueprint_id": "bp_test_123"
        }
      },
      "assertions": {
        "cards_must_include_types": ["routine"],
        "quality_ok": true,
        "pm_treatment_must_not_contain_concepts": ["RETINOID", "TRETINOIN", "ADAPALENE", "TAZAROTENE", "RETINOL"],
        "pm_treatment_should_suggest": ["AZELAIC_ACID", "NIACINAMIDE"]
      }
    },
    {
